# Core App Settings
APP_NAME="SIET Portal API"
APP_VERSION="1.0.0"
ENV="development" # Options: development, testing, production
DEBUG=True
API_PREFIX="/api/v1"
LOG_LEVEL="INFO" # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Database Configuration
DATABASE_URL="postgresql+asyncpg://postgres:postgrespassword@localhost:5432/siet_db"
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# JWT Authentication Config
JWT_SECRET="supersecretjwtkey" # Set to a secure random string in production
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookies Configuration (Authentication/Sessions)
COOKIE_SECURE=False # Set to True in production (requires HTTPS)
COOKIE_SAMESITE="lax"
COOKIE_DOMAIN="" # Specific domain (e.g. .siet.in) or empty for current domain
ACCESS_COOKIE_NAME="access_token"
REFRESH_COOKIE_NAME="refresh_token"

# Email Provider Settings
EMAIL_PROVIDER="resend"
EMAIL_API_KEY="" # Put Resend API Key here

# Meilisearch Config
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="masterKeySecret123" # Put Meilisearch master key here

# R2 Cloud Storage Settings (AWS S3 Compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Internal Communications
INTERNAL_API_KEY="internal-api-key-secret" # Used for securing inter-service revalidation & indexing requests

# Allowed CORS Origins (comma separated)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Networking Settings
REQUEST_TIMEOUT=30
